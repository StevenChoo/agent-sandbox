# ── Agent user mapping ────────────────────────────────────────────────────────
# Must match your host user so the agent can read mounted files (e.g. ~/.claude).
# Run: id -u && id -g
# Linux default: 1000 / 1000
# macOS default: 501  / 20  (staff group)
AGENT_UID=1000
AGENT_GID=1000

# ── MCP: Context7 ─────────────────────────────────────────────────────────────
CONTEXT7_API_KEY=your-context7-api-key-here

# Host home directory path — adjust for the machine running the container
# Linux: /home/yourname    macOS: /Users/yourname
HOST_HOME=/home/johndoe

# ── Shell landing directory ────────────────────────────────────────────────────
# Directory to land in when attaching to the container shell.
# Must be a path that exists inside the container (i.e. a mounted directory).
WORK_DIR=/home/agent/Development/projects/ai-build
